# Augur Environment Configuration
# Copy this to .env and fill in values.
# NEVER commit .env to version control.

# FRED API (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# PostgreSQL Database
DATABASE_URL=postgresql://augur:password@localhost:5432/augur
# Or individual components:
DB_USER=augur
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=augur

# ACLED API (free registration: https://acleddata.com/register/)
# Phase 2 — not needed for initial build
# ACLED_API_KEY=
# ACLED_EMAIL=

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

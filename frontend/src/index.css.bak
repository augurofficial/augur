
/* ================================================================
   LANDING PAGE STYLES
   ================================================================ */

.landing {
  overflow-x: hidden;
}

/* ---- Hero ---- */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(217, 64, 64, 0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(217, 64, 64, 0.03) 0%, transparent 50%),
    linear-gradient(180deg, #0b0b0f 0%, #0f0f18 50%, #0b0b0f 100%);
  z-index: 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 720px;
  padding: 0 32px;
  animation: fadeIn 1s ease;
}

.hero-pre {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--text-secondary);
  font-weight: 300;
  font-style: italic;
  margin-bottom: 24px;
  letter-spacing: 0.5px;
  animation: fadeIn 1s ease 0.2s both;
}

.hero-title {
  font-family: var(--font-display);
  font-size: 96px;
  font-weight: 400;
  letter-spacing: 28px;
  color: #ffffff;
  line-height: 1;
  margin-bottom: 12px;
  background: linear-gradient(180deg, #ffffff 0%, #ddddee 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: fadeIn 1s ease 0.4s both;
}

.hero-subtitle {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 6px;
  color: var(--accent-red);
  text-transform: uppercase;
  margin-bottom: 40px;
  font-weight: 400;
  animation: fadeIn 1s ease 0.6s both;
}

.hero-description {
  font-family: var(--font-body);
  font-size: 17px;
  color: #ccccdd;
  line-height: 1.8;
  font-weight: 300;
  max-width: 560px;
  margin: 0 auto 40px;
  animation: fadeIn 1s ease 0.8s both;
}

.hero-actions {
  display: flex;
  gap: 20px;
  justify-content: center;
  align-items: center;
  animation: fadeIn 1s ease 1s both;
}

.hero-cta {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #ffffff;
  background: var(--accent-red);
  padding: 14px 32px;
  text-decoration: none;
  transition: all 0.3s ease;
  font-weight: 400;
}

.hero-cta:hover {
  background: #c03535;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(217, 64, 64, 0.3);
}

.hero-secondary {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  text-decoration: none;
  padding: 14px 24px;
  border: 1px solid var(--border-subtle);
  transition: all 0.3s ease;
}

.hero-secondary:hover {
  color: var(--text-primary);
  border-color: var(--border-hover);
}

.scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  animation: fadeIn 1s ease 1.5s both;
}

.scroll-indicator span {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-dim);
}

.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(180deg, var(--text-dim), transparent);
  animation: scrollPulse 2s ease infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* ---- Content Sections ---- */
.content-section {
  padding: 100px 32px;
  max-width: 960px;
  margin: 0 auto;
}

.dark-section {
  max-width: 100%;
  background: var(--bg-accent);
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
}

.dark-section .section-inner {
  max-width: 960px;
  margin: 0 auto;
}

.section-inner {
  max-width: 960px;
}

.section-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent-red);
  font-weight: 500;
  display: block;
  margin-bottom: 16px;
}

.section-title {
  font-family: var(--font-display);
  font-size: 36px;
  font-weight: 400;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 32px;
}

.section-body p {
  font-size: 17px;
  color: #ccccdd;
  line-height: 1.9;
  font-weight: 300;
  margin-bottom: 20px;
  max-width: 640px;
}

.section-body-intro {
  font-size: 17px;
  color: var(--text-secondary);
  line-height: 1.9;
  font-weight: 300;
  margin-bottom: 40px;
  max-width: 640px;
}

/* ---- Pull Quote ---- */
.pull-quote {
  font-family: var(--font-display);
  font-size: 24px;
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.6;
  padding: 32px 0 32px 28px;
  border-left: 3px solid var(--accent-red);
  margin: 40px 0;
  max-width: 560px;
}

.quote-context {
  display: block;
  font-size: 14px;
  color: var(--text-muted);
  font-style: normal;
  font-family: var(--font-mono);
  margin-top: 12px;
  letter-spacing: 0.5px;
}

/* ---- Pillars Grid ---- */
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.pillar-block {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  padding: 28px;
  transition: border-color 0.3s ease;
}

.pillar-block:hover {
  border-color: var(--border-hover);
}

.pillar-block-title {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--accent-red);
  font-weight: 500;
  margin-bottom: 16px;
}

.pillar-indicators {
  list-style: none;
}

.pillar-indicators li {
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--text-secondary);
  padding: 6px 0;
  border-bottom: 1px solid var(--border-subtle);
  font-weight: 300;
}

.pillar-indicators li:last-child {
  border-bottom: none;
}

/* ---- Empire Timeline ---- */
.empire-timeline {
  position: relative;
  padding-left: 32px;
}

.empire-timeline::before {
  content: '';
  position: absolute;
  left: 7px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(180deg, var(--accent-red), var(--border-subtle));
}

.empire-entry {
  display: flex;
  gap: 24px;
  padding: 20px 0;
  position: relative;
}

.empire-marker {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--bg-primary);
  border: 2px solid var(--accent-red);
  position: absolute;
  left: -32px;
  top: 24px;
  z-index: 1;
}

.empire-name {
  font-family: var(--font-display);
  font-size: 20px;
  color: var(--text-primary);
  font-weight: 400;
  margin-bottom: 4px;
}

.empire-years {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 0.5px;
}

.empire-cause {
  font-family: var(--font-body);
  font-size: 14px;
  color: var(--text-secondary);
  margin-top: 8px;
  font-weight: 300;
  line-height: 1.6;
}

/* ---- Principles Grid ---- */
.principles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.principle {
  padding: 24px;
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  transition: all 0.3s ease;
}

.principle:hover {
  border-color: var(--border-hover);
  transform: translateY(-2px);
}

.principle-number {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent-red);
  font-weight: 500;
  letter-spacing: 1px;
}

.principle-title {
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--text-primary);
  font-weight: 400;
  margin: 12px 0 8px;
  line-height: 1.4;
}

.principle-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.6;
  font-weight: 300;
}

/* ---- CTA Section ---- */
.cta-section {
  text-align: center;
  padding: 120px 32px;
}

.cta-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cta-title {
  font-family: var(--font-display);
  font-size: 48px;
  font-weight: 400;
  color: var(--text-primary);
  margin-bottom: 16px;
  font-style: italic;
}

.cta-description {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 32px;
  letter-spacing: 0.5px;
}

.cta-links {
  margin-top: 32px;
  display: flex;
  gap: 16px;
  align-items: center;
}

.cta-links a {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.3s ease;
}

.cta-links a:hover {
  color: var(--accent-red);
}

.cta-divider {
  color: var(--text-dim);
}

/* ---- Dashboard Nav ---- */
.dashboard-nav {
  padding: 20px 0;
}

.nav-back {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.3s ease;
}

.nav-back:hover {
  color: var(--accent-red);
}

/* ---- Landing Footer ---- */
.landing-footer {
  padding: 40px 32px;
  text-align: center;
  border-top: 1px solid var(--border-subtle);
}

.landing-footer p {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 3px;
  color: var(--text-dim);
  text-transform: uppercase;
}

.footer-small {
  font-size: 11px !important;
  letter-spacing: 0.5px !important;
  text-transform: none !important;
  max-width: 560px;
  margin: 12px auto 0;
  line-height: 1.6;
}

/* ---- Reveal Animations ---- */
.reveal-section {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.reveal-section.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ---- Responsive ---- */
@media (max-width: 768px) {
  .hero-title {
    font-size: 56px;
    letter-spacing: 14px;
  }

  .hero-actions {
    flex-direction: column;
  }

  .pillars-grid {
    grid-template-columns: 1fr;
  }

  .principles-grid {
    grid-template-columns: 1fr;
  }

  .content-section {
    padding: 64px 24px;
  }

  .section-title {
    font-size: 28px;
  }

  .cta-title {
    font-size: 32px;
  }
}
